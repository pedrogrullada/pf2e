        },
        {
            "_id": "KjPocmq2jVAJwC6V",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Hellfume Body",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>A fumecrux's body consists of hellish fumes infused with void energy. When a creature that's holding its breath while it has been Swallowed Whole by a fumecrux attacks or casts a spell on a turn, the creature loses 3 rounds of air instead of 2.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
