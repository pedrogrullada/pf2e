        },
        {
            "_id": "hy3xmOn9wQpZt0ZZ",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Spit Up",
            "sort": 800000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 2
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> The draconic fumecrux has a creature Swallowed Whole</p><hr /><p><strong>Effect</strong> The draconic fumecrux spits out the swallowed creature, flinging it through the air up to 40 feet away. The creature takes bludgeoning damage equal to the distance it traveled and lands @UUID[Compendium.pf2e.conditionitems.Item.Prone]. If it lands in the same space as another creature, the other creature is pushed 5 feet and takes @Damage[(3d8+4)[bludgeoning]] damage (@Check[reflex|dc:25|basic] save). The fumecrux can't Spit Up more than one creature at a time no matter their size, and the most recently swallowed creature is Spit Up first.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
