        {
            "_id": "4dOF92ZHlnfvcC4d",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Aura of Blight",
            "sort": 400000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "description": {
                    "value": "<p>15 feet. The sarcovalt is surrounded by a miasma of infection. An enemy that enters or ends their turn in the aura must attempt a @Check[fortitude|dc:25] save.</p><hr /><p><strong>Success</strong> The creature is unaffected and becomes temporarily immune to the aura for 1 minute.</p>\n<p><strong>Failure</strong> Until the end of its next turn, the creature takes a –1 circumstance penalty to saves against disease effects.</p>\n<p><strong>Critical Failure</strong> Until the end of its next turn, the creature takes a –2 circumstance bonus against disease effects and is @UUID[Compendium.pf2e.conditionitems.Item.Enfeebled]{Enfeebled 2}.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
                },
                "rules": [
                    {
                        "key": "Aura",
                        "radius": 15,
