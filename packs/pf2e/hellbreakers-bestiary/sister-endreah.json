                "category": "offensive",
                "description": {
                    "value": "<p><strong>Requirements</strong> Sister Endreah is wielding an asp coil</p><hr /><p><strong>Effect</strong> Sister Endreah is an expert at using her sword in close quarters. Her asp coil loses the reach weapon property, but she can make asp coil Strikes instead of fist Strikes when she uses Flurry of Blows. Claw of pain also applies to these asp coil Strikes when in this stance.</p>"
                },
                "publication": {
                    "license": "OGL",
                    "remaster": false,
                    "title": ""
