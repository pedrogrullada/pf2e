            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "offensive",
                "description": {
                    "value": "<p>When Sister Endreah targets the same creature with two Strikes from her Flurry of Blows, she can cause lingering pain. If either Strike hits and deals damage, the target must succeed at a @Check[fortitude|dc:21] save or take @Damage[1d4[persistent,mental]] damage (and become @UUID[Compendium.pf2e.conditionitems.Item.Sickened]{Sickened 1} on a critical failure).</p>"
                },
