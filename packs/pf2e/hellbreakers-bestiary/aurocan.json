        {
            "_id": "xapYwUQW11nlSLyd",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Blistering Touch",
            "sort": 500000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p>The aurocan funnels some of the steam powering it into its body, heating up its metal frame. For the next minute, its melee Strikes deal an additional 1d6 fire damage.</p>"
                },
                "publication": {
                    "license": "OGL",
