        {
            "_id": "TAmNSJZovywGonCZ",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Cloud of Plague",
            "sort": 600000,
            "system": {
                "actionType": {
                    "value": "free"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "deathNote": true,
                "description": {
                    "value": "<p><strong>Trigger</strong> Ezio is reduced to 0 HP</p><hr /><p><strong>Effect</strong> Ezio's body explodes in a bloody mist that carries a deadly plague. Each living creature in a @Template[type:emanation|distance:15] must succeed at a @Check[fortitude|dc:22] save or contract choking death at stage 1 (stage 2 on a critical failure). Ezio bursts forth from the corpse of the first creature to die of this affliction, fully healed, but if all affected creatures are cured of the disease, Ezio is permanently destroyed.</p>"
                },
