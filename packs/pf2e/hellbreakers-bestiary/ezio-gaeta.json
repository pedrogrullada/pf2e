                        "option": "change-shape",
                        "selection": "vampire",
                        "suboptions": [
                            {
                                "label": "PF2E.NPCAbility.ChangeShape.Form.Vampire",
                                "value": "vampire"
                            },
                            {
                                "label": "PF2E.NPCAbility.ChangeShape.Form.Swarm.Flies",
                                "value": "swarm"
                            }
                        ],
                        "toggleable": true,
                        "value": true
                    },
