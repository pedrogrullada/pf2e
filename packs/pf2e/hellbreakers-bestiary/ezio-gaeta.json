        },
        {
            "_id": "WClX8uSElJUKVPTM",
            "folder": "Pycs65tqRMBiiARd",
            "img": "systems/pf2e/icons/actions/Passive.webp",
            "name": "Coffin Restoration",
            "sort": 700000,
            "system": {
                "actionType": {
                    "value": "passive"
                },
                "actions": {
                    "value": null
                },
                "category": "defensive",
                "deathNote": true,
                "description": {
                    "value": "<p>Unlike other undead, a vampire isn't destroyed at 0 HP. Instead, it falls @UUID[Compendium.pf2e.conditionitems.Item.Unconscious]. If its body rests in its coffin for 1 hour, the vampire gains 1 HP, after which its fast healing begins to function normally.</p>"
                },
                "publication": {
                    "license": "ORC",
                    "remaster": true,
                    "title": "Pathfinder Monster Core"
                },
                "rules": [],
                "slug": "vampire-basic-coffin-restoration",
                "traits": {
