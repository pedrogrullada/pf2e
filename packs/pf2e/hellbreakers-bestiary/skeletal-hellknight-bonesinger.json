        },
        {
            "_id": "FSEozSpG3gJKBYjt",
            "img": "systems/pf2e/icons/default-icons/action.svg",
            "name": "Invoke Reckoning",
            "sort": 1300000,
            "system": {
                "actionType": {
                    "value": "action"
                },
                "actions": {
                    "value": 1
                },
                "category": "offensive",
                "description": {
                    "value": "<p><strong>Frequency</strong> once per round</p>\n<p><strong>Requirements</strong> The skeletal Hellknight bonesinger's last action was to damage an enemy with a melee Strike</p><hr /><p><strong>Effect</strong> The bonesinger pulls at the bones of the creature they just damaged, releasing a pulse of void energy. That creature takes @Damage[4d8[void]] damage and must attempt a @Check[fortitude|dc:23] save.</p><hr /><p><strong>Critical Success</strong> The creature takes no damage.</p>\n<p><strong>Success</strong> The creature takes half damage.</p>\n<p><strong>Failure</strong> The creature takes full damage.</p>\n<p><strong>Critical Failure</strong> The creature takes full damage and is @UUID[Compendium.pf2e.conditionitems.Item.Drained]{Drained 1}.</p>"
                },
                "publication": {
                    "license": "OGL",
